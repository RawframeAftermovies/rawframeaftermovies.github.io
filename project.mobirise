        "display1Font": "Open Sans",
        "display1Size": "4.6",
        "display2Font": "Open Sans",
        "display2Size": 3,
        "display5Font": "Open Sans",
        "display5Size": 2,
        "display7Font": "Open Sans",
        "display7Size": "1.0",
        "display4Font": "Open Sans",
        "display4Size": 1.1,
        "isRoundedButtons": false,
        "isGhostButtonBorder": false,
        "underlinedLinks": false,
        "isAnimatedOnScroll": false,
        "isScrollToTopButton": false
      },
      "titlePreset": "Portfolio",
      "nameSelectPreset": "portfolio",
      "presetSourceTheme": "mobirise5",
      "additionalSetColors": [
        "#fc0909"
      ]
    },
    "path": "@PROJECT_PATH@",
    "name": "RAWFRAME",
    "versionFirst": "5.7.8",
    "siteFonts": [
      {
        "css": "'Lexend', sans-serif",
